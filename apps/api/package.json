{
  "name": "@hellcifegeek/api",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "images:cache": "tsx src/scripts/cache-product-images.ts",
    "test": "jest --runInBand",
    "test:watch": "jest --watch"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "rootDir": ".",
    "testRegex": ".*(\\.spec|\\.e2e-spec)\\.ts$",
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "clearMocks": true
  },
  "dependencies": {
    "@nestjs/common": "^11.1.23",
    "@nestjs/core": "^11.1.23",
    "@nestjs/platform-express": "^11.1.23",
    "@supabase/supabase-js": "^2.106.1",
    "dotenv": "^17.4.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.24",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.15.18",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.22.3",
    "typescript": "^5.8.3"
  }
}
