{
  "name": "hellcifegeek",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @hellcifegeek/web",
    "dev:api": "npm run dev -w @hellcifegeek/api",
    "build": "npm run build -w @hellcifegeek/web",
    "build:api": "npm run build -w @hellcifegeek/api",
    "start": "npm run start -w @hellcifegeek/web",
    "start:api": "npm run start -w @hellcifegeek/api",
    "images:cache": "npm run images:cache -w @hellcifegeek/api",
    "images:normalize": "npm run images:normalize -w @hellcifegeek/api",
    "typecheck": "npm run typecheck -w @hellcifegeek/web",
    "typecheck:api": "npm run typecheck -w @hellcifegeek/api",
    "test:api": "npm test -w @hellcifegeek/api"
